{
  "expo": {
    "name": "BarLog",
    "slug": "barlog-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "barlog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.barlog.mobile"
    },
    "android": {
      "package": "app.barlog.mobile",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#101014"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "BarLog needs camera access to capture your sip moments."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "BarLog needs photo access to upload drink images."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "BarLog needs media access to save and share drink cards."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BarLog uses your location to find nearby bars."
        }
      ],
      "expo-font"
    ]
  }
}
